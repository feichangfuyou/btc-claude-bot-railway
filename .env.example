# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── Optional: Frontend (Vite) ─────────────────────────────────────────────────
# Dev defaults to direct backend (http://localhost:8000). Override if needed:
# VITE_BACKEND_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000/ws
#
# WebSocket needs the backend running. Start it with: python backend.py

# ─── Optional: Coinbase (for authenticated price feed) ────────────────────────
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ─── Optional: API Security (REQUIRED for any exposed deployment) ─────────────
# When unset: API/dashboard unprotected; /emergency/stop only allowed from localhost.
# Never deploy to a public host without setting this.
BOT_API_SECRET=

# ─── Optional: Database (Docker uses /app/data/bot.db) ────────────────────────
# DB_PATH=bot.db

# ─── Trading Mode ────────────────────────────────────────────────────────────
# Capital: $2.5k–5k minimum to make a dent (fees 1.2% + AI ~$0.03/trade).
# With $1k, positions are $100–250 — costs eat profits; consider fewer coins or higher START_BALANCE.
PAPER_TRADING=true
START_BALANCE=1000
TARGET_BALANCE=5000
# Min per trade (default 75). Below ~$75, round-trip fees + AI cost usually exceed profit.
# MIN_TRADE_USD=75

# Stop loss: multiply preset SL ATR by this. 1.0=preset only, 1.3=30% wider (default), 1.5=50% wider.
# SL_ATR_WIDEN=1.3
# Wider stop = less premature exits (crypto volatility). Recommended: 1.5
# TRAILING_STOP_PCT=1.5
# Min net profit per trade after fees/AI. If costs ~$2/trade, use ≥5 to make it worthwhile.
# MIN_PROFIT_AFTER_COSTS=5.0
# Stale exit: close positions held >N min with tiny P&L (-0.5% to +1%). Default: 90
# STALE_POSITION_MIN=90

# Trading preset: legendary trader strategies (turtle, soros, ptj, livermore,
# seykota, druckenmiller, kovner, minervini, williams_balanced, williams_swing,
# raschke, crypto_swing, crypto_conservative). Default: turtle
# TRADING_PRESET=turtle

# Max concurrent positions. With small capital ($1k), use 3–4 so each position is larger.
# MAX_CONCURRENT_POSITIONS=8

# ─── Approval & direction bias ─────────────────────────────────────────────
# Require your approval before each trade (reduces risk, clearer control)
# REQUIRE_TRADE_APPROVAL=true
# Direction: long (buy only) | short (sell only) | both (no restriction)
# DIRECTION_BIAS=both
# Seconds to wait for approval before auto-rejecting. Default: 120
# PENDING_TRADE_TIMEOUT_SEC=120

# ─── Futures / Perpetuals (INTX) ────────────────────────────────────────────
# ENABLE_FUTURES=false
# FUTURES_LEVERAGE=2
# MAX_FUTURES_POSITIONS=3
# FUTURES_LIVE=false
# TRADE_MODE=spot
# PERPETUALS_PORTFOLIO_UUID=

# Scout gate — loosen to escalate more often (manual Ask Claude skips scout)
# SCOUT_MIN_SIGNALS=2       # signals to escalate (default 2)
# SCOUT_MIN_CONFIDENCE=0.35 # min confidence to escalate (default 0.35)

# ─── Optional: Speed tunables (fail-fast, no hanging) ───────────────────────────
# PRICE_FETCH_TIMEOUT=4    # sec for price APIs (Coinbase, Binance REST)
# API_PROXY_TIMEOUT=4      # sec for backend proxy (Fear&Greed, exchange)
# CLAUDE_API_TIMEOUT=25    # sec for Haiku/Sonnet; Opus models use 75s (they reason longer)
# FALLBACK_POLL_SEC=4      # fallback price poll when WS disconnected (default 4)

# ─── Optional: Claude interval & risk limits ─────────────────────────────────
# CLAUDE_INTERVAL=90        # seconds between AI cycles (default 90)
# TEST_MODE=true            # true = paper trading mode (default true)
# MAX_DAILY_LOSS_PCT=0.05   # max daily loss as fraction of balance (default 0.05)
# MAX_DRAWDOWN_PCT=0.20     # max drawdown before kill switch (default 0.20)
# MAX_POSITION_SIZE=0.25    # max single position as fraction of balance (default 0.25)
# MIN_POSITION_SIZE=0.10    # min position as fraction of balance (default 0.10)
# MAX_POSITION_USD=500      # max single position in USD (default 500)
# MAX_CONSEC_LOSSES=4       # circuit breaker trips after N losses (default 4)
# TRADE_COOLDOWN_SEC=60     # seconds between trades (default 60)
# BREAKEVEN_TRIGGER_PCT=1.0 # move SL to breakeven at this % profit (default 1.0)
# COINS=BTC,ETH,SOL,LINK    # comma-separated coin list

# ─── Optional: Kraken ────────────────────────────────────────────────────────
# ENABLE_KRAKEN=false
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=

# ─── Optional: On-chain / CDP (for live on-chain swaps) ──────────────────────
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
# CDP_WALLET_SECRET=
# CDP_WALLET_ADDRESS=
# NETWORK_ID=base-mainnet
# MIN_ETH_GAS=0.0005

# ─── Optional: CORS (for exposed deployments) ────────────────────────────────
# CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ─── Optional: Frontend auth ─────────────────────────────────────────────────
# VITE_BOT_API_SECRET=      # must match BOT_API_SECRET for dashboard access

# ─── Supabase (Multi-User Platform) ──────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
# Frontend (Vite) — must be prefixed with VITE_
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Add redirect URLs in Supabase: Auth > URL Configuration
#   Dev:  http://localhost:5173/oauth/callback
#   Prod: https://your-domain.com/oauth/callback

# ─── Stripe Billing (Subscriptions) ──────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_STARTER=price_xxx
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_ELITE=price_xxx

# ─── Optional: Notifications ──────────────────────────────────────────────────
WEBHOOK_URL=

# ─── Optional: Intent-Based Solver (UniswapX / CoW Swap) ─────────────────────
# Instead of direct DEX swaps, express "intents" — solvers compete for best price.
# Saves ~1-2% per trade in slippage + gas.
# SOLVER_NETWORK=auto           # auto | uniswapx | cowswap (auto tries both)
# SOLVER_SLIPPAGE_BPS=50        # max slippage in basis points (50 = 0.5%)
# SOLVER_DEADLINE_SEC=120       # intent expiry in seconds

# ─── Optional: Vision Integration (Chart Analysis) ───────────────────────────
# Claude "sees" 15m + 4h charts to confirm market structure before trading.
# ENABLE_VISION=false
# VISION_MODEL=claude-sonnet-4-6
# CHART_CACHE_SEC=120           # how long to cache chart screenshots

# ─── Optional: Trade Screenshots ─────────────────────────────────────────────
# Capture chart screenshots at trade entry/exit for visual review.
# Requires Playwright (pip install playwright && playwright install chromium).
# Falls back to static TradingView chart images if Playwright unavailable.
# TRADE_SCREENSHOT_DIR=trade_screenshots

# ─── Optional: KYA Compliance (Know Your Agent) ──────────────────────────────
# Cryptographic identity + reasoning audit trail for every decision.
# BOT_DID_SEED=                 # deterministic DID seed (auto-generated if empty)
# ENABLE_AUDIT_LOG=true         # store full reasoning traces in DB
# AUDIT_RETENTION_DAYS=365      # how long to keep audit entries
