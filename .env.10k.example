# 10K Public Launch — copy to .env and fill secrets
# See docs/RUNBOOK.md "Flip to 10K Mode" checklist

# ─── Required for 10k ───────────────────────────────────────────────────────
SCALE_10K=true
BOT_API_SECRET=                    # openssl rand -hex 32
REDIS_URL=redis://localhost:6379    # or Upstash/Railway link
ANTHROPIC_API_KEYS=key1,key2,key3  # 10+ keys for 10k users
DATABASE_URL=                      # or SUPABASE_DB_PASSWORD from Supabase Connect

# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── Stripe (for purchases) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx   # python scripts/create_stripe_webhook.py https://api.doyou.trade/billing/webhook
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ELITE=price_xxx
APP_URL=https://doyou.trade         # frontend URL for Stripe redirects

# ─── Security ────────────────────────────────────────────────────────────────
EXCHANGE_KEYS_ENCRYPTION_KEY=       # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CORS_ORIGINS=https://doyou.trade,https://www.doyou.trade

# ─── Optional ───────────────────────────────────────────────────────────────
# SENTRY_DSN=
# ANTHROPIC_API_KEY=sk-ant-xxx      # fallback if ANTHROPIC_API_KEYS not set
